# Database
DB_PASSWORD=change-this-strong-password
DB_PORT=5433

# Application
JWT_SECRET=replace-with-a-base64-secret-at-least-256-bits
AI_PROVIDER=xfyun-spark
AI_BASE_URL=https://spark-api-open.xf-yun.com/v1
AI_COMPLETIONS_PATH=/chat/completions
AI_API_KEY=replace-with-your-xfyun-spark-api-password
AI_CHAT_MODEL=lite
AI_CHAT_TEMPERATURE=0.7

# Shared iFlytek credentials for TTS and HiDream image generation
XFYUN_APP_ID=replace-with-your-xfyun-app-id
XFYUN_API_KEY=replace-with-your-xfyun-api-key
XFYUN_API_SECRET=replace-with-your-xfyun-api-secret
XFYUN_IMAGE_PROVIDER=hidream

# Alibaba Cloud Bailian Embedding
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024

# Alibaba Cloud Bailian vision model for uploaded image understanding.
# Leave DASHSCOPE_VL_API_KEY unset to reuse DASHSCOPE_API_KEY.
DASHSCOPE_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_VL_MODEL=qwen-vl-plus

# Docker deployment does not require Ollama; local development can still use agent-qwen-tools.
FRONTEND_PORT=3000
BACKEND_PORT=3001
REDIS_PORT=3002
